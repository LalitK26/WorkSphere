## Copy to /etc/dashboard/dashboard.env and set actual values. Keep file mode 600 and owned by root.

# Database Configuration
DB_URL=jdbc:mysql://127.0.0.1:3306/dashboard
DB_USERNAME=dashboard_user
DB_PASSWORD=change_me

# Security Configuration
JWT_SECRET=replace_with_256bit_random_value

# Email Configuration
MAIL_USERNAME=workspheredashboard@gmail.com
MAIL_PASSWORD=change_me

# Google Services
GOOGLE_MAPS_API_KEY=change_me

# File Storage
FILE_UPLOAD_DIR=/opt/apps/dashboard-api/uploads
LOG_PATH=/opt/logs/api

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://dashboard.worksphere.ltd,https://recruitment.worksphere.ltd

# WebRTC Configuration
# TURN server settings (coturn)
WEBRTC_TURN_ENABLED=true
WEBRTC_TURN_URL=turn:recruitment.worksphere.ltd:3478
WEBRTC_TURN_USERNAME=worksphere_turn_user
WEBRTC_TURN_CREDENTIAL=change_this_turn_password_to_strong_value
WEBRTC_TURN_PROTOCOL=udp

# WebSocket Configuration
WEBRTC_WS_ENDPOINT=https://api.worksphere.ltd/ws
WEBRTC_WS_ALLOWED_ORIGINS=https://recruitment.worksphere.ltd,https://dashboard.worksphere.ltd
WEBRTC_WS_CONNECTION_TIMEOUT=30000
WEBRTC_WS_MAX_MESSAGE_SIZE=1048576

# WebRTC Signaling Configuration
WEBRTC_MAX_PARTICIPANTS=2
WEBRTC_SESSION_TIMEOUT=1800000
WEBRTC_ENABLE_LOGGING=false

# QuickeKYC API Configuration
QUICKEKYC_API_KEY=your_api_key_here
QUICKEKYC_BASE_URL=https://api.quickekyc.com/api/v1
