# Environment Configuration Template
# Copy this to .env.development or .env.production

# API Configuration
VITE_API_BASE_URL=http://localhost:8080
VITE_APP_ENV=development

# WebSocket Configuration
VITE_WS_URL=http://localhost:8080/ws

# WebRTC STUN servers
VITE_STUN_SERVER_1=stun:stun.l.google.com:19302
VITE_STUN_SERVER_2=stun:stun1.l.google.com:19302
VITE_STUN_SERVER_3=stun:stun2.l.google.com:19302

# TURN server
VITE_TURN_ENABLED=false
VITE_TURN_URL=turn:recruitment.worksphere.ltd:3478
VITE_TURN_USERNAME=your_turn_username
VITE_TURN_CREDENTIAL=your_turn_password

# Debug mode
VITE_DEBUG_MODE=true
